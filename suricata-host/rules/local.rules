# =========================
# ICMP
# =========================

drop icmp any any -> any any (
    msg:"IPS - Ping bloqueado";
    sid:1000001;
    rev:1;
)

# =========================
# Port Scan
# =========================

alert tcp any any -> any any (
    msg:"IDS - Possivel port scan";
    flags:S;
    threshold:type both, track by_src, count 20, seconds 10;
    sid:1000002;
    rev:1;
)

# =========================
# Tentativa de acesso SSH
# =========================

alert tcp any any -> any 22 (
    msg:"IDS - Tentativa de acesso SSH";
    sid:1000003;
    rev:1;
)

# =========================
# Bloqueio HTTP suspeito
# =========================

drop http any any -> any any (
    msg:"IPS - User-Agent suspeito";
    content:"curl";
    http_user_agent;
    sid:1000004;
    rev:1;
)

# =========================
# Tentativa básica de SQL Injection
# =========================

alert http any any -> any any (
    msg:"IDS - Possivel SQL Injection";
    content:"' OR 1=1";
    nocase;
    sid:1000005;
    rev:1;
)